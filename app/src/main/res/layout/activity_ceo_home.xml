<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".CeoHomeActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- WELCOME CEO BOX with curve -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/ceo_welcome_bg"
            android:padding="20dp">

            <TextView
                android:id="@+id/welcomeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome CEO"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:background="@color/appcolor"
                android:layout_centerInParent="true" />
        </RelativeLayout>

        <!-- Buttons above Top Employees -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnLeaderboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@color/appcolor"
                android:text="Leaderboard"
                android:layout_marginEnd="8dp"/>

           <!-- <Button
                android:id="@+id/btnAddEmployee"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:background="@color/appcolor"
                android:layout_weight="1"
                android:text="Add New Employee"
                android:layout_marginStart="7dp"/>-->
        </LinearLayout>

        <!-- Top Employees Horizontal RecyclerView -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Top Employees"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="16dp"
            android:textColor="#000000"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/topEmployeesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:orientation="horizontal"
            android:scrollbars="horizontal" />

        <!-- Active Projects -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Active Projects"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="16dp"
            android:textColor="#000000"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/activeProjectsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:padding="16dp" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textSize="16sp"
            android:backgroundTint="#B00020"
            android:textColor="#FFFFFF"
            android:minHeight="48dp"
            android:layout_marginBottom="16dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
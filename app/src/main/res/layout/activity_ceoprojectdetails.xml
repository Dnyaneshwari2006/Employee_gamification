<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F7FA">

    <!-- Fixed Section: Heading -->
    <TextView
        android:id="@+id/projectTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="UX Research Method – Surja"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#2C3E50"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="4dp" />

    <!-- Blue Underline -->
    <View
        android:layout_width="90dp"
        android:layout_height="3dp"
        android:layout_marginBottom="12dp"
        android:background="#3498DB" />

    <!-- Project Info -->
    <TextView
        android:id="@+id/projectDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Discover core principles of UX Research. Designed to deepen understanding of user behavior."
        android:textSize="15sp"
        android:textColor="#555555"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/projectCreatedAt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Starting Date: 2024-03-27"
        android:textColor="#2C3E50"
        android:textSize="14sp"
        android:layout_marginBottom="6dp" />

    <!-- Horizontal Layout for Deadline and Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/projectDeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deadline: 2024-04-10"
            android:padding="6dp"
            android:textSize="13sp"
            android:textColor="#C0392B"
            android:background="@drawable/tag_background_red"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/projectStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Active"
            android:padding="6dp"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#27AE60"
            android:background="@drawable/tag_background_green" />
    </LinearLayout>

    <!-- Scrollable Section -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Employees Container -->
            <LinearLayout
                android:id="@+id/employeesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:elevation="2dp"
                android:padding="10dp"
                android:backgroundTint="#FFFFFF"
                android:clipToPadding="false"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp" />

            <!-- Project Tasks Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Project Tasks"
                android:textSize="20sp"
                android:textStyle="bold"
                android:padding="10dp" />

            <!-- RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>

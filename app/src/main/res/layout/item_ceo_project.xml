<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    card_view:cardCornerRadius="12dp"
    card_view:cardElevation="6dp"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Project Title -->
        <TextView
            android:id="@+id/projectName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Project Title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#222222" />

        <!-- Project Deadline or Metadata -->
        <TextView
            android:id="@+id/projectDeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deadline: 25 April 2025"
            android:textSize="14sp"
            android:textColor="#777777"
            android:layout_marginTop="4dp" />

        <!-- Optional Project Status -->
        <TextView
            android:id="@+id/projectStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Active"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#0F9D58"
            android:layout_marginTop="6dp"
            android:background="#E6F4EA"
            android:padding="4dp"
            android:visibility="gone" /> <!-- Optional: show only if needed -->

    </LinearLayout>

</androidx.cardview.widget.CardView>
